# ===========================================
# ContextOS - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# --- Gemini AI ---
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- NextAuth.js ---
# Generate a strong secret: run `openssl rand -base64 32` in your terminal
NEXTAUTH_SECRET=your_nextauth_secret_here

# --- NextAuth URL ---
# For local development:
NEXTAUTH_URL=http://localhost:3000
# For production (Vercel), this is set automatically.

# --- Google OAuth Provider ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new project
# 2. Go to "OAuth consent screen" → configure it
# 3. Go to "Credentials" → Create "OAuth 2.0 Client ID"
# 4. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Domain Lock ---
# Only users with this email domain will be allowed access.
# Change this to your actual company domain.
ALLOWED_EMAIL_DOMAIN=firmdomain.com
